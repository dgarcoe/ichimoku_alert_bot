# Copy this file to `.env` and fill in real values.
# Docker Compose picks it up automatically.

# ---- Telegram ----
# Create a bot via @BotFather and paste its token here.
TELEGRAM_BOT_TOKEN=123456789:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA
# Your own chat ID (or comma-separated list for multiple recipients).
# After you /start your bot, message @userinfobot to find your chat ID.
TELEGRAM_CHAT_IDS=123456789

# ---- Runtime ----
LOG_LEVEL=INFO
